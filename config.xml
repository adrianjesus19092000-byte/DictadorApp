<?xml version='1.0' encoding='utf-8'?>
<widget id="com.adrian.dictadorpro" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    
    <name>Dictador Pro</name>
    <description>Aplicación para dictado de secuencias numéricas.</description>
    <author email="adrianjesus19092000@gmail.com">Adrián Mejías</author>
    
    <content src="index.html" />
    
    <preference name="Orientation" value="landscape" />
    <preference name="Fullscreen" value="true" />

    <icon src="icon.png" />

    <preference name="SplashScreen" value="screen" />
    <preference name="SplashScreenDelay" value="3000" />
    <preference name="FadeSplashScreen" value="true" />
    <preference name="FadeSplashScreenDuration" value="500" />
    
    <platform name="android">
        <splash src="splash.png" />
    </platform>
    <plugin name="cordova-plugin-tts" spec="^0.2.3" />

</widget>
